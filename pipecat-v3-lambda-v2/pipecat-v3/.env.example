# Daily.co (voice rooms)
DAILY_API_KEY=your_daily_api_key
DAILY_API_URL=https://api.daily.co/v1

# Optional: Langfuse / OTLP tracing
ENABLE_TRACING=false
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64_encoded_api_key>

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# LLM: AWS Bedrock (or set OPENAI_API_KEY for OpenAI)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-west-2
# AWS_SESSION_TOKEN=  # optional for temporary credentials

# Optional: OpenAI (if not using Bedrock)
# OPENAI_API_KEY=sk-...

# Cartesia TTS/STT
CARTESIA_API_KEY=your_cartesia_api_key

# WhatsApp (Twilio template)
WHATSAPP_TEMPLATE_SID=your_whatsapp_template_sid

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Google Calendar (path to OAuth client secret JSON)
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
# GOOGLE_OAUTH_TOKEN=  # set by generate_oauth_token.py after first auth

# Langfuse (optional tracing)
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# Server
PORT=7860
