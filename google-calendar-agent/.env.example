# Copy to .env and fill in your values. Never commit .env.

# Daily.co
DAILY_API_KEY=your_daily_api_key
DAILY_API_URL=https://api.daily.co/v1

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# AWS Bedrock (or OpenAI)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-west-2

# OpenAI (optional)
# OPENAI_API_KEY=sk-...

# Cartesia
CARTESIA_API_KEY=your_cartesia_api_key

# WhatsApp template (Twilio)
WHATSAPP_TEMPLATE_SID=your_whatsapp_template_sid

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Google: path to OAuth client secret (from Google Cloud Console)
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
